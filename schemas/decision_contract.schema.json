{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://charenix.com/schemas/afu-brain/decision-contract.schema.json",
  "title": "Afu Brain Decision Contract",
  "type": "object",
  "required": ["intent", "risk", "decision", "can_execute", "skills", "reason"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["hearing", "mood", "clarify", "contract", "file_search", "receipt", "email", "travel", "payment", "delete"]
    },
    "risk": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "ask", "block"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "can_execute": {
      "type": "boolean"
    },
    "allowed_preparation": {
      "type": "boolean"
    },
    "required_confirmation": {
      "type": "boolean"
    },
    "blocked_final_action": {
      "type": ["string", "null"]
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "source_policy_version": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
