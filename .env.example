# Copy to .env for local development.
# Do not commit .env.

AFU_BRAIN_MODE=local

# Optional: subscribe to public shared brain upgrades.
# Leave empty to run fully disconnected.
AFU_BRAIN_FEED_URL=https://charenix.com/api/afu-brain/feed/latest

# Optional model provider keys. Users bring their own.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional executor integration.
OPENCLAW_ENDPOINT=http://127.0.0.1:7777
OPENCLAW_TOKEN=

# Optional local memory location. Keep owner data outside git.
AFU_OWNER_MEMORY_DIR=./owner-data

